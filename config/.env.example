# SentinelAI Environment Variables
# Copy this file to .env and fill in your actual values
# Usage: cp config/.env.example .env

# ── Anthropic (required) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Used by all 5 agents:
#   OrchestratorAgent  -> claude-opus-4-8 (adaptive thinking)
#   MarketIntelAgent   -> claude-sonnet-4-6
#   RiskGuardAgent     -> claude-sonnet-4-6
#   SecurityAuditAgent -> claude-haiku-4-5-20251001
#   ExecutionAgent     -> claude-haiku-4-5-20251001

# ── CoinMarketCap AI Agent Hub (required) ─────────────────────────────────────
CMC_API_KEY=...
# Get free key at: https://coinmarketcap.com/api/
# Used for: Fear & Greed, trending tokens, price/volume, global metrics

# ── BSCScan (required for contract auditing) ───────────────────────────────────
BSCSCAN_API_KEY=...
# Get free key at: https://bscscan.com/apis
# Used for: fetching verified Solidity source code before each trade

# ── Trust Wallet Agent Kit (required for execution) ───────────────────────────
TWAK_MODE=cli
# Options: "cli" (default) | "mcp"
#   cli: uses `twak` CLI binary (npm install -g @trustwallet/agent-kit)
#   mcp: uses TWAK MCP HTTP server at TWAK_MCP_URL

TWAK_WALLET=0x...
# Your agent wallet BSC address (public, used for competition registration)
# Example: 0xAbCd1234...

TWAK_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12
# BIP-39 mnemonic for the agent wallet (TWAK manages this locally)
# NEVER commit this to git — TWAK reads it from env for local signing
# Keys never leave your machine — all signing is done locally by TWAK

TWAK_WALLET_PRIVATE_KEY=0x...
# Alternative to mnemonic: raw private key (hex, with 0x prefix)
# Only one of TWAK_MNEMONIC or TWAK_WALLET_PRIVATE_KEY is needed
# TWAK uses whichever is present for local keystore initialization

TWAK_MCP_URL=http://localhost:3000
# Only required when TWAK_MODE=mcp

# ── BNB Chain RPC (required for on-chain reads) ────────────────────────────────
BSC_RPC_URL=https://bsc-dataseed1.binance.org/
# Public BSC RPC endpoints (no key needed):
#   https://bsc-dataseed1.binance.org/
#   https://bsc-dataseed2.binance.org/
#   https://bsc-dataseed.binance.org/
# Or use a paid provider for reliability:
#   Quicknode: https://your-endpoint.bsc.quiknode.pro/YOUR_KEY/
#   Alchemy:   https://bnb-mainnet.g.alchemy.com/v2/YOUR_KEY
#   NodeReal:  https://bsc-mainnet.nodereal.io/v1/YOUR_KEY

# ── Optional tuning ───────────────────────────────────────────────────────────
CYCLE_INTERVAL=300         # Seconds between trading cycles (default: 300 = 5 min)
START_VALUE=100.0          # Starting portfolio value in USD (for PnL tracking)
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
DRY_RUN=false              # true = simulate all trades without sending transactions

# ── Competition registration ───────────────────────────────────────────────────
# Contract: 0x212c61b9b72c95d95bf29cf032f5e5635629aed5 (BSC mainnet)
# DEADLINE: before June 22 2026 (trading window opens)
# Command:  python main.py --register
# This calls: twak compete register  (signs + broadcasts locally via TWAK)
