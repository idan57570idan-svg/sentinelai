# SentinelAI Environment Variables
# Copy this file to .env and fill in your actual values

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...           # Claude API key (all 5 agents)
CMC_API_KEY=...                        # CoinMarketCap Pro API key
BSCSCAN_API_KEY=...                    # BSCScan API key (contract source fetch)

# ── Trust Wallet Agent Kit ────────────────────────────────────────────────────
TWAK_MODE=cli                          # "cli" or "mcp"
TWAK_WALLET=0x...                      # Your agent wallet address (BSC)
TWAK_MCP_URL=http://localhost:3000    # If using MCP mode

# ── Optional ──────────────────────────────────────────────────────────────────
CYCLE_INTERVAL=300                     # Seconds between trading cycles (default 300)
START_VALUE=100.0                      # Starting portfolio value in USD
LOG_LEVEL=INFO

# ── Competition ───────────────────────────────────────────────────────────────
# Competition contract: 0x212c61b9b72c95d95bf29cf032f5e5635629aed5 (BSC mainnet)
# Register before June 22 2026: python main.py --register
